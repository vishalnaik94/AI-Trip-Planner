# ============================================
# LOCAL DEVELOPMENT (use these for local setup)
# ============================================

# Database — local dev uses individual params (do NOT set DATABASE_URL locally)
# DATABASE_URL is auto-provided by Railway in production
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=user
DB_PASSWORD=password
DB_NAME=tripplanner

# Auth
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_secret

# AI (required)
GEMINI_API_KEY=your_gemini_api_key

# Vector Store (optional — falls back gracefully)
PINECONE_API_KEY=your_pinecone_key
PINECONE_INDEX=trip-planner-index

# External APIs (optional — uses mock data if missing)
AMADEUS_CLIENT_ID=your_amadeus_id
AMADEUS_CLIENT_SECRET=your_amadeus_secret

# Redis (optional)
REDIS_URL=redis://localhost:6379

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ============================================
# RAILWAY DEPLOYMENT (set these in Railway dashboard)
# ============================================
# DATABASE_URL        → auto-injected by Railway PostgreSQL addon
# PORT                → auto-injected by Railway
# NODE_ENV            → set to "production"
# GEMINI_API_KEY      → your Google Gemini key
# JWT_SECRET          → a strong random secret
# FRONTEND_URL        → your Vercel frontend URL (e.g. https://your-app.vercel.app)
